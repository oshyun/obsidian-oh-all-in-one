{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowSyntheticDefaultImports": true,
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
		"moduleResolution": "node",
		"lib": ["ES6", "DOM"]
	},
	"include": ["**/*.ts"]
}
